# ============================================================
#  Many Minds — .gitignore (public shell)
# ============================================================

# ---- Secrets — never commit ----
.env
.env.*
*.key
*.pem

# ---- Python ----
.venv/
venv/
__pycache__/
*.pyc
*.pyo

# ---- OS junk ----
.DS_Store
Thumbs.db

# ---- Local / runtime artifacts ----
logs/
*.xlsx
